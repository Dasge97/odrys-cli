#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "${SOURCE_PATH}" ]; do
  LINK_DIR="$(cd "$(dirname "${SOURCE_PATH}")" && pwd)"
  SOURCE_PATH="$(readlink "${SOURCE_PATH}")"
  [[ "${SOURCE_PATH}" != /* ]] && SOURCE_PATH="${LINK_DIR}/${SOURCE_PATH}"
done
ROOT_DIR="$(cd "$(dirname "${SOURCE_PATH}")/.." && pwd)"
LOCAL_GO="${HOME}/.local/go/bin/go"

if [ -x "${ROOT_DIR}/dist/odrys" ]; then
  exec "${ROOT_DIR}/dist/odrys" "$@"
fi

if [ -x "${LOCAL_GO}" ]; then
  exec "${LOCAL_GO}" run "${ROOT_DIR}/cmd/odrys" "$@"
fi

if command -v go >/dev/null 2>&1; then
  exec go run "${ROOT_DIR}/cmd/odrys" "$@"
fi

echo "Odrys requiere Go o un binario compilado en dist/odrys." >&2
exit 1
