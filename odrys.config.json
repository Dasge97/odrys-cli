{
  "provider": {
    "name": "openai",
    "model": "gpt-5.1-codex-max"
  },
  "workspace": {
    "path": ".",
    "include": [
      "go.mod",
      "README.md",
      "cmd",
      "internal",
      "project"
    ],
    "exclude": [
      ".git",
      "opencode-dev",
      "dist",
      "build",
      "coverage",
      ".go-cache",
      ".go-mod-cache",
      ".go-path"
    ]
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git rev-parse --is-inside-work-tree": "allow",
      "git status --short": "allow"
    },
    "edit": {
      "*": "ask",
      ".odrys-sandbox/**": "allow"
    },
    "list": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "search": {
      "*": "allow"
    }
  },
  "worker": {
    "maxReviewLoops": 2,
    "planner": {
      "auto": true
    },
    "summarizeOnSuccess": true
  },
  "session": {
    "autoResume": true,
    "contextMessages": 8,
    "contextRuns": 4,
    "contextFiles": 6
  }
}
